# إعدادات قاعدة البيانات (اتركه فارغاً للتجربة المحلية أو ضع رابط PostgreSQL للرفع)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# إعدادات Google Drive (يتم استخراجها من ملف JSON الخاص بـ Service Account)
GOOGLE_CLIENT_EMAIL="your-service-account-email@your-project-id.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# إعدادات الحماية (JWT)
JWT_ACCESS_SECRET="your-super-secret-access-key-change-me"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-me"

# منفذ تشغيل الخادم
PORT=3001
